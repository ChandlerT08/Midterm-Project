async function fight(num){

    const bossName = document.getElementById("bossName");
    const bossRepose = document.getElementById("bossRepose");
    const playerRepose = document.getElementById("playerRepose");

    const keys = ['w','a','s','d'];

    let parries = 0;
    let totalAttacks = 6;

    switch(num){
        case 0:
            bossName.textContent = "Spine Hydra";
            break;
    }

    for(let i = 0; i < totalAttacks; i++){

        let keyIndex = Math.floor(Math.random()*4);

        let success = await attack(keys[keyIndex], 1000);

        if(success){
            parries++;
        }

    }

    resolveFight(parries, totalAttacks, bossRepose, playerRepose);
}



//

function attack(key, timeLimit){

    const keyBox = document.getElementById("keyBox");

    keyBox.textContent = key;

    return new Promise(resolve => {

        let finished = false;

        function handleKey(e){

            if(finished) return;

            if(e.key === key && !e.repeat){
                finished = true;
                window.removeEventListener("keydown", handleKey);
                resolve(true); // parry success
            }

        }

        window.addEventListener("keydown", handleKey);

        setTimeout(() => {

            if(finished) return;

            finished = true;
            window.removeEventListener("keydown", handleKey);
            resolve(false); // miss

        }, timeLimit);

    });
}

//

function resolveFight(parries, totalAttacks, bossRepose, playerRepose){

    document.getElementById("keyBox").style.display = "none";

    bossRepose.value -= (parries * 10);
    playerRepose.value -= ((totalAttacks - parries) * 8);

}


